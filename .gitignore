```gitignore
# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Virtual Environments
# ==========================================
.venv/
venv/
env/

# ==========================================
# Flask
# ==========================================
instance/
.flaskenv

# ==========================================
# Environment Variables
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# SQLite Databases
# ==========================================
*.db
*.sqlite
*.sqlite3

# ==========================================
# Logs
# ==========================================
*.log
logs/

# ==========================================
# Testing & Coverage
# ==========================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ==========================================
# Type Checker / Linter Cache
# ==========================================
.mypy_cache/
.ruff_cache/
.pyre/

# ==========================================
# Build / Distribution
# ==========================================
build/
dist/
*.egg-info/
.eggs/

# ==========================================
# Temporary Files
# ==========================================
tmp/
temp/

# ==========================================
# Database Backups
# ==========================================
backups/
*.bak

# ==========================================
# VS Code
# ==========================================
.vscode/

# ==========================================
# JetBrains IDE
# ==========================================
.idea/

# ==========================================
# Jupyter
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Operating System Files
# ==========================================
.DS_Store
Thumbs.db
desktop.ini
```
